# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Capacitor: the web build gets copied into these on every `cap sync`/`cap
# copy` — regenerated, not source. Everything else in android/ and ios/
# (manifests, icons, Xcode/Gradle project files) is real project source.
android/app/src/main/assets/public
android/app/src/main/assets/capacitor.config.json
ios/App/App/public
ios/App/App/capacitor.config.json

# Android Studio / Gradle build output and machine-local config
android/.gradle
android/build
android/app/build
android/local.properties
android/captures
android/*.iml

# Xcode per-user state and build output
ios/App/.build
ios/App/*.xcodeproj/xcuserdata
ios/App/*.xcodeproj/project.xcworkspace/xcuserdata
ios/App/Pods
ios/App/Podfile.lock
